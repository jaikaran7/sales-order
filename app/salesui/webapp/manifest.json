{
  "_version": "1.83.0",
  "sap.app": {
    "id": "sales.salesui",
    "type": "application",
    "title": "Sales Dashboard",
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/sales/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {}
      }
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "settings": {
          "operationMode": "Server"
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "sales.salesui.view",
        "controlId": "app",
        "controlAggregation": "pages"
      },
      "routes": [
        {
          "pattern": "",
          "name": "dashboard",
          "target": "dashboard"
        }
      ],
      "targets": {
        "dashboard": {
          "viewName": "Dashboard"
        }
      }
    }
  }
}